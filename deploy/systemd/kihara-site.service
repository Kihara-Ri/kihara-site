[Unit]
Description=Kihara Personal Site
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/kihara-site/backend
ExecStart=/opt/kihara-site/release/kihara-site
Restart=always
RestartSec=3

Environment=PORT=8080
Environment=ARTICLE_DIR=/opt/kihara-site/backend/articles
Environment=TAG_CONFIG_PATH=/opt/kihara-site/backend/tag_config.yaml
# Optional override:
# Environment=STATIC_DIR=/opt/kihara-site/frontend/dist

[Install]
WantedBy=multi-user.target
